msgstr "Babeskopia osatu da."

#: qt/shutdowndlg.py:35
msgid "Cancel Shutdown"
msgstr "Utzi itzalketa"

#: qt/shutdowndlg.py:36
msgid "Shutdown Now"
msgstr "Itzali orain"

