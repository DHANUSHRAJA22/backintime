msgstr ""
"دایرکتوری برگرفت که باید فایل پیکربندی را از آن وارد کنید انتخاب کنید. مسیر "
"ممکن است به صورت زیر باشد: {samplePath}"

#: qt/restoreconfigdialog.py:169
msgid ""
"If the directory is located on an external or remote drive, it must be "
