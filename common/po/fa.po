msgstr "اثر انگشت کلید {keytype} عبارت است از:"

#: qt/manageprofiles/tab_general.py:534
msgid "Please verify this fingerprint. Add it to the 'known_hosts' file?"
msgstr ""
"لطفا این اثر انگشت را تأیید کنید. آیا به پرونده 'known_hosts' اضافه شود؟"

#: qt/manageprofiles/tab_general.py:618
msgid "Really change the backup directory?"
msgstr "آیا واقعا میخواهید پوشه پشتیبان‌گیری را تغییر دهید؟"

#: qt/manageprofiles/tab_general.py:651
#, python-brace-format
msgid "Failed to create new SSH key in {path}."
msgstr "ایجاد کلید SSHجدید در {path} ناموفق بود."

#: qt/manageprofiles/tab_options.py:37
msgid "Enable notifications"
msgstr "فعال کردن اعلان‌ها"

#: qt/manageprofiles/tab_options.py:41
msgid "Disable backups when on battery"
msgstr "غیرفعال کردن پشتیبان‌گیری‌ها زمان استفاده از باتری"

#: qt/manageprofiles/tab_options.py:47
msgid "Power status not available from system"
msgstr "وضعیت باتری از طرف سیستم در دسترس نیست"

#: qt/manageprofiles/tab_options.py:49
msgid "Run only one backup at a time"
msgstr "اجرای فقط یک پشتیبان‌گیری در زمان"

#: qt/manageprofiles/tab_options.py:53
msgid ""
"Other backups will be blocked until the current backup is completed. This is"
" a global setting, meaning it will affect all profiles for this user. "
"However, it must also be activated for all other users."
msgstr ""
"سایر پشتیبان‌گیری‌ها تا زمانی که پشتیبان‌گیری فعلی کامل نشده مسدود خواهند "
"شد. این یک تنظیم سراسری است، به این معنا که بر تمام نمایه‌های این کاربر "
"تأثیر خواهد گذاشت. با این حال، باید برای سایر کاربران نیز فعال شود."

#: qt/manageprofiles/tab_options.py:60
msgid "Backup replaced files on restore"
msgstr "پشتیبان‌گیری از فایل‌های تغییر مکان یافته در هنگام بازگردانی"

#: qt/manageprofiles/tab_options.py:75
msgid "Continue on errors (keep incomplete backups)"
msgstr "ادامه در صورت بروز خطا (نگه‌داشتن پشتیبان‌های کامل نشده)"

#: qt/manageprofiles/tab_options.py:79
msgid "Use checksum to detect changes"
msgstr "از سرجمع برای شناسایی تغییرات استفاده کن"

#: qt/manageprofiles/tab_options.py:83
msgid "Create a new backup whether there were changes or not."
msgstr "چه تغییرات صورت گرفته باشد یا نه، یک پشتیبان جدید ایجاد کن."

#: qt/manageprofiles/tab_options.py:92
msgid "Warn if the free disk space falls below"
msgstr ""

#: qt/manageprofiles/tab_options.py:98
msgid ""
"Shows a warning when free space on the backup destination disk is less than "
"the specified value."
msgstr ""

#: qt/manageprofiles/tab_options.py:100
msgid ""
"If the Remove & Retention policy is enabled and old backups are removed "
"based on available free space, this value cannot be lower than the value set"
" in the policy."
msgstr ""

#: qt/manageprofiles/tab_options.py:118
msgid "Log Level:"
msgstr "سطح لاگ:"

#: qt/manageprofiles/tab_options.py:178
msgid "None"
msgstr "هیچکدام"

#: qt/manageprofiles/tab_remove_retention.py:197
#, python-brace-format
msgid ""
"The following rules are processed from top to bottom. Later rules override "
"earlier ones. See the {manual} for details and examples."
msgstr ""
"قوانین زیر از بالا به پایین پردازش می‌شوند. قوانین بعدی بر قوانین قبلی "
"اولویت دارند. برای جزئیات و نمونه‌ها به {manual} مراجعه کنید."

#: qt/manageprofiles/tab_remove_retention.py:202
msgid "user manual"
msgstr "راهنمای کاربر"

#: qt/manageprofiles/tab_remove_retention.py:215
msgid "Open user manual in browser."
msgstr "باز کردن راهنمای کاربر در مرورگر."

#: qt/manageprofiles/tab_remove_retention.py:229
msgid "Keep the most recent backup."
msgstr "جدیدترین پشتیبان را نگه دار."

#: qt/manageprofiles/tab_remove_retention.py:233
msgid "The last or freshest backup is kept under all circumstances."
msgstr "آخرین یا جدیدترین پشتیبان تحت هر شرایطی حفظ می‌شود."

#: qt/manageprofiles/tab_remove_retention.py:235
msgid "That behavior cannot be changed."
msgstr "رفتار نمی تواند تغییر کند."

#: qt/manageprofiles/tab_remove_retention.py:247
msgid "Keep named backups."
msgstr "پشتیبان‌های نام‌گذاری‌شده را نگه دار."

#: qt/manageprofiles/tab_remove_retention.py:250
msgid ""
"Backups that have been given a name, in addition to the usual timestamp, "
"will be retained under all circumstances and will not be removed."
msgstr ""
"پشتیبان‌هایی که علاوه بر زمان‌سنجی معمول، نام‌گذاری شده‌اند، تحت هر شرایطی "
"حفظ خواهند شد و حذف نخواهند شد."

#: qt/manageprofiles/tab_remove_retention.py:265
msgid "Year(s)"
msgstr "سال(ها)"

#: qt/manageprofiles/tab_remove_retention.py:270
msgid "Remove backups older than"
msgstr "حذف پشتیبان‌های قدیمی‌تر از"

#: qt/manageprofiles/tab_remove_retention.py:276
msgid "Full days. Current day is ignored."
msgstr "روزهای کامل. روز جاری نادیده گرفته می‌شود."

#: qt/manageprofiles/tab_remove_retention.py:278
msgid "Calendar weeks with Monday as first day. Current week is ignored."
msgstr ""
"هفته‌های تقویم با دوشنبه به عنوان اولین روز. هفته جاری نادیده گرفته می‌شود."

#: qt/manageprofiles/tab_remove_retention.py:281
msgid "12 months periods. Current month is ignored."
msgstr "دوره‌های ۱۲ ماهه. ماه جاری نادیده گرفته می‌شود."

#: qt/manageprofiles/tab_remove_retention.py:296
msgid "Retention policy"
msgstr "سیاست‌های نگهداری"

#: qt/manageprofiles/tab_remove_retention.py:301
msgid "Run in background on remote host."
msgstr "در پس‌زمینه برروی میزبان راه‌دور اجرا کن."

#: qt/manageprofiles/tab_remove_retention.py:304
msgid ""
"The smart remove procedure will run directly on the remote machine, not "
"locally. The commands \"bash\", \"screen\", and \"flock\" must be installed "
"and available on the remote machine."
msgstr ""
"فرآیند حذف هوشمند مستقیما روی ماشین راه دور اجرا می‌شود، نه به‌صورت محلی. "
"دستورات \"bash\"، \"screen\" و \"flock\" باید روی ماشین راه دور نصب و در "
"دسترس باشند."

#: qt/manageprofiles/tab_remove_retention.py:308
msgid "If selected, Back In Time will first test the remote machine."
msgstr ""
"اگر این گزینه انتخاب شود، Back In Time ابتدا ماشین راه دور را آزمایش خواهد "
"کرد."

#: qt/manageprofiles/tab_remove_retention.py:312
msgid "The days are counted starting from today."
msgstr "روزها از امروز شمرده می‌شوند."

#: qt/manageprofiles/tab_remove_retention.py:313
msgid "Keep all backups for the last"
msgstr "تمام پشتیبان‌ها را برای همیشه نگه دار"

#: qt/manageprofiles/tab_remove_retention.py:318
#: qt/manageprofiles/tab_remove_retention.py:330
msgid "day(s)."
msgstr "روز‌(ها)."

#: qt/manageprofiles/tab_remove_retention.py:325
msgid "Keep the last backup for each day for the last"
msgstr "آخرین پشتیبان هر روز را برای همیشه نگه دار"

#: qt/manageprofiles/tab_remove_retention.py:335
msgid ""
"The weeks are counted starting from the current running week. A week starts "
"on Monday."
msgstr ""
"هفته‌ها از هفته جاری که در حال اجرا است شروع می‌شوند. هفته از روز دوشنبه "
"آغاز می‌شود."

#: qt/manageprofiles/tab_remove_retention.py:338
msgid "Keep the last backup for each week for the last"
msgstr "آخرین پشتیبان هر هفته را برای همیشه نگه دار"

#: qt/manageprofiles/tab_remove_retention.py:343
msgid "week(s)."
msgstr "هفته(ها)."

#: qt/manageprofiles/tab_remove_retention.py:348
msgid ""
"The months are counted as calendar months starting with the current month."
msgstr "ماه‌ها به‌عنوان ماه‌های تقویمی از ماه جاری شمرده می‌شوند."

#: qt/manageprofiles/tab_remove_retention.py:351
msgid "Keep the last backup for each month for the last"
msgstr "آخرین پشتیبان هر ماه را برای همیشه نگه دار"

#: qt/manageprofiles/tab_remove_retention.py:356
msgid "month(s)."
msgstr "ماه(ها)."

#: qt/manageprofiles/tab_remove_retention.py:361
msgid ""
"The years are counted as calendar years starting with the current year."
msgstr "سال‌ها به‌عنوان سال‌های تقویمی از سال جاری شمرده می‌شوند."

#: qt/manageprofiles/tab_remove_retention.py:363
msgid "Keep the last backup for each year for"
msgstr "آخرین پشتیبان هر سال را نگه دار برای"

#: qt/manageprofiles/tab_remove_retention.py:365
msgid "all years."
msgstr "تمام سال ها."

#: qt/manageprofiles/tab_remove_retention.py:380
msgid "… the free space is less than"
msgstr "... فضای آزاد کمتر باشد از"

#: qt/manageprofiles/tab_remove_retention.py:385
msgid "… the free inodes are less than"
msgstr "... در صورتی که تعداد inode آزاد کمتر باشد از"

#: qt/manageprofiles/tab_remove_retention.py:394
msgid "Remove oldest backup if …"
msgstr "قدیمی‌ترین پشتیبان را حذف کن اگر …"

