#: qt/snapshotsdialog.py:110
#, python-brace-format
msgid "No parameters set for the diff command. Using default value \"{params}\"."
msgstr ""
"Aucun paramètre n'a été défini pour la commande diff. Utilisation de la "
"valeur par défaut \"{params}\"."

